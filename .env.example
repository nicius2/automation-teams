# ============================================================
#  MICROSOFT AZURE CREDENTIALS
#  Obtenha em: https://portal.azure.com/#view/Microsoft_AAD_RegisteredApps
# ============================================================

# ID do aplicativo registrado no Azure Active Directory
AZURE_CLIENT_ID=f57e5307-abae-406c-aafc-f2ac4843a839

# ID do tenant (diretório) — ou "common" para contas pessoais/multi-tenant
AZURE_TENANT_ID=9f153027-cacd-456c-9fd2-66180bb7fdfb

# ============================================================
#  WHATSAPP NOTIFICAÇÕES
# ============================================================

# Número para receber as notificações (formato: DDI+DDD+número, ex: 5511999998888)
WHATSAPP_TARGET_PHONE=5598992278632

# URL do servidor Baileys local
BAILEYS_SERVER_URL=http://localhost:3000

# ============================================================
#  CONFIGURAÇÕES DO MONITOR
# ============================================================

# Nome alvo a monitorar (case-insensitive, separados por vírgula)
MENTION_TARGETS=jose

# Horário de início do monitoramento (formato HH:MM)
MONITOR_START_TIME=08:00

# Horário de fim do monitoramento (formato HH:MM)
MONITOR_END_TIME=18:00

# Intervalo de verificação em minutos
CHECK_INTERVAL_MINUTES=5

# Porta do servidor Baileys
BAILEYS_PORT=3000
