# ============================================================
#  BROWSER / PLAYWRIGHT
#  true  = roda em background silencioso (RECOMENDADO - padrão)
#  false = NÃO USE (legacy) - o sistema abre visível automaticamente quando precisa de login
# ============================================================

BROWSER_HEADLESS=true


# ============================================================
#  TELEGRAM BOT
#
#  1. Fale com @BotFather → /newbot → copie o token
#  2. Envie uma mensagem ao bot e rode:
#       python main.py --get-chat-id
#  3. Cole o chat_id abaixo
# ============================================================

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Timeout para requisições Telegram (em segundos)
# Aumentado para 20s pois a API pode ser lenta
TELEGRAM_REQUEST_TIMEOUT=


# ============================================================
#  CONFIGURAÇÕES DO MONITOR
# ============================================================

# Nome(s) a monitorar no Teams (separados por vírgula, case-insensitive)
MENTION_TARGETS=

# Horário de funcionamento
MONITOR_START_TIME=
MONITOR_END_TIME=

# Intervalo de verificação em SEGUNDOS (sobrescreve CHECK_INTERVAL_MINUTES)
# 10 = verifica a cada 10 segundos (recomendado para resposta rápida)
# Se preferir minutos, deixe em branco e use CHECK_INTERVAL_MINUTES abaixo
CHECK_INTERVAL_SECONDS=

# Intervalo de verificação em MINUTOS (usado se CHECK_INTERVAL_SECONDS estiver vazio)
# Exemplo: 5 = verifica a cada 5 minutos
# CHECK_INTERVAL_MINUTES=5
